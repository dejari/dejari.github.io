I_PROP_OUTPUT_PORT|outTables|0":"|Output table 1|Output tables","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"version":1,"stepReference":{"type":"uri","path":"/dataFlows/steps/ab59f8c4-af9a-4608-a5d5-a8365357bb99"},"arguments":{"codeOptions":{"code":"import numpy as np\nimport pandas as pd\nfrom sklearn.cluster import KMeans\nimport swat\nfrom sklearn import decomposition\nimport os\n\n## Getting input & output tables ready\n_input1 = 'casuser.final_dataset'\n_output1 = 'casuser.flow_result'\n\ndf = SAS.sd2df(_input1)\n\ndf2 = df[['Prin1', 'Prin2']].copy()\ndf2 = np.array(df2)\n\n### creating Kmeans object using  KMeans()\nkmean = KMeans(n_clusters = 3, random_state=1)\n\n### Fit on data\nkmean.fit(df2)\n\n### labels\nprint(kmean.labels_)\nX_1 = kmean.labels_\nX_1 = np.reshape(X_1, (len(X_1),1))\nprint(X_1.shape)\nprint(df2.shape)\n\n### Adding gender column\nnp.random.seed(124458)\ngender = np.random.choice(a = ['M', 'F'], size = 8636, p = [0.4, 0.6])\ngender = gender.reshape(8636,1)\n\narr = df[[\"CUST_ID\", \"BALANCE\", \"PURCHASES\", 'ONEOFF_PURCHASES', \"CASH_ADVANCE\" , \"CREDIT_LIMIT\" , \"PAYMENTS\"]]\n\nfinal_data_cluster = pd.DataFrame((np.concatenate((np.array(arr), gender, df2, X_1), axis = 1)), columns = [\"CUST_ID\", \"BALANCE\", \"PURCHASES\", 'ONEOFF_PURCHASES', \"CASH_ADVANCE\" , \"CREDIT_LIMIT\" , \"PAYMENTS\", 'GENDER', 'C1','C2','Cluster'])\n\nSAS.df2sd(final_data_cluster, _output1)","contentType":"embedded","logHTML":"","resultsHTML":"","variables":[{"name":"_input1","value":{"portIndex":0,"portName":"inTables","referenceType":"inputPort"}},{"name":"_output1","value":{"arguments":{},"portIndex":0,"portName":"outTables","referenceType":"outputPort"}}]}},"portMappings":[{"mappingType":"tableStructure","portName":"outTables","portIndex":0,"tableStructure":{"columnDefinitions":[]}}]},"id-1730470122513-1783":{"description":"","id":"id-1730470122513-1783","name":"SAS Program 2","nodeType":"step","note":null,"priority":2,"p